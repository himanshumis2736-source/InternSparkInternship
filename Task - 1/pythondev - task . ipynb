        "import os\n",
        "import shutil\n",
        "import csv\n",
        "from datetime import datetime\n",
        "\n",
        "# -------------------------------\n",
        "# LOG FUNCTION\n",
        "# -------------------------------\n",
        "\n",
        "def write_log(message):\n",
        "    with open(\"log.txt\", \"a\") as log_file:\n",
        "        log_file.write(f\"{datetime.now()} - {message}\\n\")\n",
        "\n",
        "\n",
        "# -------------------------------\n",
        "# CREATE DEMO FOLDER\n",
        "# -------------------------------\n",
        "\n",
        "folder_name = \"automation_demo\"\n",
        "\n",
        "try:\n",
        "    if not os.path.exists(folder_name):\n",
        "        os.mkdir(folder_name)\n",
        "        print(\"Folder created successfully\")\n",
        "        write_log(\"Folder created\")\n",
        "\n",
        "except Exception as e:\n",
        "    print(\"Error creating folder:\", e)\n",
        "    write_log(f\"Error creating folder: {e}\")\n",
        "\n",
        "\n",
        "# -------------------------------\n",
        "# USER INPUT FILE\n",
        "# -------------------------------\n",
        "\n",
        "file_name = input(\"Enter text file name (example: demo.txt): \")\n",
        "\n",
        "file_path = os.path.join(folder_name, file_name)\n",
        "\n",
        "try:\n",
        "    with open(file_path, \"w\") as file:\n",
        "        file.write(\"This is a sample automation file.\\n\")\n",
        "        file.write(\"Python internship task.\\n\")\n",
        "\n",
        "    print(\"File created and data written\")\n",
        "    write_log(f\"File created: {file_name}\")\n",
        "\n",
        "except Exception as e:\n",
        "    print(\"Error writing file:\", e)\n",
        "    write_log(f\"Error writing file: {e}\")\n",
        "\n",
        "\n",
        "# -------------------------------\n",
        "# READ FILE\n",
        "# -------------------------------\n",
        "\n",
        "try:\n",
        "    with open(file_path, \"r\") as file:\n",
        "        content = file.read()\n",
        "\n",
        "    print(\"\\nFile Content:\")\n",
        "    print(content)\n",
        "\n",
        "    write_log(f\"File read successfully: {file_name}\")\n",
        "\n",
        "except Exception as e:\n",
        "    print(\"Error reading file:\", e)\n",
        "    write_log(f\"Error reading file: {e}\")\n",
        "\n",
        "\n",
        "# -------------------------------\n",
        "# RENAME FILE\n",
        "# -------------------------------\n",
        "\n",
        "new_name = input(\"\\nEnter new file name: \")\n",
        "\n",
        "new_file_path = os.path.join(folder_name, new_name)\n",
        "\n",
        "try:\n",
        "    os.rename(file_path, new_file_path)\n",
        "\n",
        "    print(\"File renamed successfully\")\n",
        "    write_log(f\"File renamed from {file_name} to {new_name}\")\n",
        "\n",
        "except Exception as e:\n",
        "    print(\"Error renaming file:\", e)\n",
        "    write_log(f\"Error renaming file: {e}\")\n",
        "\n",
        "\n",
        "# -------------------------------\n",
        "# CREATE CSV FILE\n",
        "# -------------------------------\n",
        "\n",
        "csv_path = os.path.join(folder_name, \"data.csv\")\n",
        "\n",
        "try:\n",
        "    with open(csv_path, \"w\", newline=\"\") as csvfile:\n",
        "        writer = csv.writer(csvfile)\n",
        "\n",
        "        writer.writerow([\"Task\", \"Status\"])\n",
        "        writer.writerow([\"Python Automation\", \"Completed\"])\n",
        "        writer.writerow([\"File Handling\", \"Completed\"])\n",
        "\n",
        "    print(\"CSV file created\")\n",
        "    write_log(\"CSV file created\")\n",
        "\n",
        "except Exception as e:\n",
        "    print(\"Error creating CSV:\", e)\n",
        "    write_log(f\"Error creating CSV: {e}\")\n",
        "\n",
        "\n",
        "# -------------------------------\n",
        "# MOVE FILE TO ARCHIVE\n",
        "# -------------------------------\n",
        "\n",
        "archive_folder = os.path.join(folder_name, \"archive\")\n",
        "\n",
        "try:\n",
        "    if not os.path.exists(archive_folder):\n",
        "        os.mkdir(archive_folder)\n",
        "\n",
        "    shutil.move(new_file_path, archive_folder)\n",
        "\n",
        "    print(\"File moved to archive folder\")\n",
        "    write_log(f\"File moved to archive: {new_name}\")\n",
        "\n",
        "except Exception as e:\n",
        "    print(\"Error moving file:\", e)\n",
        "    write_log(f\"Error moving file: {e}\")\n",
        "\n",
        "\n",
        "# -------------------------------\n",
        "# DISPLAY FILES\n",
        "# -------------------------------\n",
        "\n",
        "try:\n",
        "    print(\"\\nCurrent files inside automation_demo:\")\n",
        "    print(os.listdir(folder_name))\n",
        "\n",
        "    write_log(\"Displayed all files\")\n",
        "\n",
        "except Exception as e:\n",
        "    print(\"Error displaying files:\", e)\n",
        "    write_log(f\"Error displaying files: {e}\")\n",
        "\n",
        "\n",
        "# -------------------------------\n",
        "# DELETE OPTION\n",
        "# -------------------------------\n",
        "\n",
        "delete_choice = input(\"\\nDo you want to delete data.csv? (yes/no): \")\n",
        "\n",
        "if delete_choice.lower() == \"yes\":\n",
        "\n",
        "    try:\n",
        "        os.remove(csv_path)\n",
        "\n",
        "        print(\"CSV file deleted\")\n",
        "        write_log(\"CSV file deleted\")\n",
        "\n",
        "    except Exception as e:\n",
        "        print(\"Error deleting CSV:\", e)\n",
        "        write_log(f\"Error deleting CSV: {e}\")\n",
        "\n",
        "else:\n",
        "    print(\"CSV file kept safely\")\n",
        "\n",
        "\n",
        "# -------------------------------\n",
        "# FINAL MESSAGE\n",
        "# -------------------------------\n",
        "\n",
        "print(\"\\nAutomation task completed successfully!\")\n",
        "write_log(\"Program completed\")"
      ]
    }
